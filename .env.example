# 策略内化层多模型调用 — 环境变量模板
# 复制本文件为 .env 并填入你自己的供应商端点和 API key
# 对应 scripts/call_model.py 的 PROVIDERS 配置

# Provider A（如 DeepSeek 等兼容 OpenAI 格式的供应商）
PROVIDER_A_BASE_URL=https://your-provider-a-endpoint.com
YOUR_API_KEY_A=sk-your-api-key-a

# Provider B（兼容 OpenAI 格式的供应商）
PROVIDER_B_BASE_URL=https://your-provider-b-endpoint.com
YOUR_API_KEY_B=sk-your-api-key-b

# Provider C（如 GPT 中转站等）
PROVIDER_C_BASE_URL=https://your-provider-c-endpoint.com
YOUR_API_KEY_C=sk-your-api-key-c
